{
  "name": "fipou",
  "version": "0.1.0",
  "private": true,
  "description": "Inteligência automotiva brasileira. Análise FIPE, depreciação, recalls, roubo e consumo.",
  "scripts": {
    "dev": "SERWIST_SUPPRESS_TURBOPACK_WARNING=1 next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check .",
    "ingest:recalls": "node scripts/ingest-recalls.mjs",
    "ingest:fuel": "node scripts/ingest-fuel-economy.mjs",
    "ingest:theft": "node scripts/ingest-theft.mjs",
    "ingest": "pnpm ingest:recalls && pnpm ingest:fuel && pnpm ingest:theft",
    "harvest": "node scripts/harvest-catalog.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.19.0",
  "dependencies": {
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fipe-promise": "^2.0.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "3.8.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@serwist/next": "^9.5.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "serwist": "^9.5.11",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3"
  }
}
