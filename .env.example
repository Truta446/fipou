# =============================================================================
# Fipou — variáveis de ambiente
#
# NENHUMA é obrigatória. O site roda 100% no free tier sem nenhuma chave.
# Copie para .env.local apenas se quiser sobrescrever algo localmente.
# =============================================================================

# URL canônica do site (NÃO é secret — só config).
# Usada por sitemap, robots, OpenGraph, canonical e JSON-LD.
# Em produção, defina no painel da Vercel. Em preview, a Vercel injeta
# VERCEL_URL automaticamente, então isto é opcional.
NEXT_PUBLIC_SITE_URL="https://fipou.com.br"

# -----------------------------------------------------------------------------
# OPCIONAL — só se um dia assinar o fipe.online (histórico de preços pago).
# Sem isto, o app usa o free tier da FIPE (mês atual), que é o padrão.
# Enviado como header X-Subscription-Token pela lib fipe-promise.
# -----------------------------------------------------------------------------
# FIPE_TOKEN=""

# -----------------------------------------------------------------------------
# FUTURO — banco e cache (Vercel Marketplace), quando entrarem os snapshots
# mensais de preço. Ainda não usados pelo código.
# -----------------------------------------------------------------------------
# DATABASE_URL="postgresql://..."          # Neon (free tier)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
